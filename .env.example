###############################################
# KUTOOT ENVIRONMENT TEMPLATE
# Copy to .env before configuring
# See ENVIRONMENTS.md for environment-specific setup
###############################################

APP_NAME=Kutoot
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE="Asia/Kolkata"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kutoot
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
OBJECT_STORAGE_DRIVER=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Logging & Debugging
LOG_VIEWER_ENABLED=true
LOG_VIEWER_EMAILS=

# Activity Logger
ACTIVITY_LOGGER_ENABLED=true
ACTIVITY_LOGGER_DB_CONNECTION=mysql

# NativePHP Mobile App
NATIVEPHP_APP_ID=com.example.app
NATIVEPHP_APP_VERSION="DEBUG"
NATIVEPHP_APP_VERSION_CODE="1"
NATIVEPHP_DEVELOPMENT_TEAM=

# CORS (comma-separated origins for kutoot-frontend; leave empty for defaults)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://kutoot.com

# Global Configurations
APP_CURRENCY=INR
PLATFORM_FEE=10
GST_RATE=18
PLATFORM_FEE_TYPE=fixed

# Razorpay (each environment should set these directly; legacy
# RAZORPAY_*_TEST_* and *_LIVE_* names are still honoured but
# we prefer the simplified variables going forward)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
PAYMENT_DEFAULT_GATEWAY=razorpay
PLAN_TAX_TYPE=exclusive

# SMS Gateway (log | way2mint)
SMS_DRIVER=log

WAY2MINT_BASE_URL=https://apibulksms.way2mint.com
WAY2MINT_USERNAME=
WAY2MINT_PASSWORD=
WAY2MINT_SENDER_ID=
WAY2MINT_PE_ID=
WAY2MINT_OTP_TEMPLATE_ID=
WAY2MINT_PROVIDER_PE_ID=

# OTP
OTP_LENGTH=4

OCTANE_SERVER=frankenphp

# Upload: single global limit in MB (used by Media Library, Filament, API). Default 100.
# Can be overridden from Admin Panel → System Settings → Object Storage.
MAX_UPLOAD_SIZE_MB=100
